# ==========================================
# MSAgentFrameworkRAG Master Git Ignore
# Covers C# ASP.NET Core, Next.js Frontend,
# Visual Studio, OS, and local agent caches.
# ==========================================

# ------------------------------------------
# User Specific & Local Uploads Ignores
# ------------------------------------------
# Ignore all local document uploads in wwwroot
**/wwwroot/uploads/*
!**/wwwroot/uploads/.gitkeep

# Ignore compiled dynamic link libraries and executables
*.dll
*.exe
*.pdb
*.suo

# Ignore local AI Agent Sandbox and cache folders
.antigravity/
**/antigravity/
.codex/
**/.codex/
brain/
**/brain/
scratch/
**/scratch/

# Ignore local SQLite databases & logging databases
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite3
**/logs/*.txt
**/logs/*.log

# ------------------------------------------
# Visual Studio (.vs, bin, obj) Ignores
# ------------------------------------------
.vs/
.vs
[Bb]in/
[Oo]bj/
[Tt]emp/
_ReSharper*/
*.[Cc]sproj.user
*.user
*.userosscache
*.sln.docstates

# ------------------------------------------
# Node.js & Next.js Ignores
# ------------------------------------------
node_modules/
/next-frontend/node_modules/
/next-frontend/.next/
/next-frontend/out/
/next-frontend/build/
/next-frontend/dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ------------------------------------------
# Environments, Secrets & Credentials
# ------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
appsettings.local.json
appsettings.Development.local.json

# ------------------------------------------
# OS & System-Specific Ignores
# ------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/



# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
*/wwwroot/storage/*
